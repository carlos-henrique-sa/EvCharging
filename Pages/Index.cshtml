@page
<!DOCTYPE html>
<html>
<head>
    <title>EV Charging Dashboard</title>
    <style>
        body {
            font-family: Arial;
            background: #0f172a;
            color: white;
            padding: 30px;
        }

        h1 {
            margin-bottom: 20px;
        }

        .card {
            background: #1e293b;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        input {
            padding: 10px;
            border-radius: 5px;
            border: none;
            width: 200px;
        }

        button {
            padding: 8px 12px;
            margin-top: 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-register { background: #3b82f6; color: white; }
        .btn-start { background: #22c55e; color: black; }
        .btn-stop { background: #ef4444; color: white; }

        .device {
            background: #334155;
            padding: 15px;
            border-radius: 8px;
            margin: 10px;
            width: 240px;
        }

        .green { color: #22c55e; }
        .red { color: #ef4444; }
        .yellow { color: #facc15; }

        .status { font-weight: bold; }
    </style>
</head>
<body>

<h1>⚡ EV Charging Dashboard</h1>

<!-- CONTROLE PARA REGISTRAR -->
<div class="card">
    <h3>Registrar estação</h3>
    <input id="stationId" value="ABC123" placeholder="Station ID" />
    <br><br>
    <button class="btn-register" onclick="register()">Registrar</button>
</div>

<!-- LISTA DE DISPOSITIVOS -->
<div class="card">
    <h3>Dispositivos Conectados</h3>
    <div id="devices" style="display:flex; flex-wrap:wrap;"></div>
</div>

<!-- SignalR Client -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/9.0.6/signalr.min.js"></script>

<script>
const stations = [];
let connection = null;

function getId() {
    return document.getElementById("stationId").value.trim();
}

// ==================== SIGNALR SETUP ====================
async function startSignalR() {
    connection = new signalR.HubConnectionBuilder()
        .withUrl("/chargingHub")
        .withAutomaticReconnect()
        .build();

    // Recebe atualizações em tempo real do servidor
    connection.on("StatusUpdated", (data) => {
        console.log("Status atualizado via SignalR:", data);
        if (data?.stationId && !stations.includes(data.stationId)) {
            stations.push(data.stationId);
        }
        updateDeviceUI(data.stationId, data.ocppStatus, data.session);
    });

    connection.on("StationRegistered", (data) => {
        console.log("Nova estação registrada via SignalR:", data);
        if (!data?.stationId) return;
        if (!stations.includes(data.stationId)) {
            stations.push(data.stationId);
        }
        updateDeviceUI(data.stationId, data.ocppStatus, data.session);
    });

    connection.on("Error", (message) => {
        console.error("SignalR Error:", message);
        alert("Erro: " + message);
    });

    try {
        await connection.start();
        console.log("✅ SignalR conectado com sucesso!");
        await loadAll();                 // carrega inicial após conectar
    } catch (err) {
        console.error("Falha ao conectar SignalR:", err);
        setTimeout(startSignalR, 5000); // tenta reconectar
    }
}

// ==================== REGISTER ====================
async function register() {
    const id = getId();
    if (!id) {
        alert("Informe um Station ID!");
        return;
    }

    if (stations.includes(id) || document.getElementById(`device-${id}`)) {
        alert("Estação já registrada!");
        return;
    }

    try {
        const response = await fetch(
            `/charging/${id}/ocpp/register?vendor=Test&model=Sim`,
            { method: 'POST' }
        );

        if (response.ok) {
            stations.push(id);
            alert(`Estação ${id} registrada com sucesso!`);
            loadAll();
        } else {
            const error = await response.text();
            alert("Erro ao registrar: " + error);
        }
    } catch (err) {
        console.error(err);
        alert("Erro de conexão ao registrar.");
    }
}

// ==================== START / STOP (via SignalR) ====================
async function start(id) {
    if (!connection) return;
    try {
        await connection.invoke("SendCommand", id, "startCharging");
    } catch (err) {
        console.error(err);
    }
}

async function stop(id) {
    if (!connection) return;
    try {
        await connection.invoke("SendCommand", id, "stopCharging");
    } catch (err) {
        console.error(err);
    }
}

// ==================== ATUALIZAÇÃO PARCIAL DO UI ====================
function updateDeviceUI(stationId, ocppStatus, session) {
    const container = document.getElementById("devices");
    let deviceDiv = document.getElementById(`device-${stationId}`);

    if (!deviceDiv) {
        // Se não existir ainda, cria o card
        deviceDiv = document.createElement("div");
        deviceDiv.id = `device-${stationId}`;
        deviceDiv.className = "device";
        container.appendChild(deviceDiv);
    }

    let ocppText = "Not registered";
    let sessionText = "Nenhuma sessão";
    let actionButton = "";

    if (ocppStatus) {
        let color = "yellow";
        if (ocppStatus.isCharging) color = "green";
        if (ocppStatus.status === "Faulted") color = "red";

        ocppText = `<span class="${color} status">${ocppStatus.status}</span>`;

        if (ocppStatus.isCharging) {
            actionButton = `<button class="btn-stop" onclick="stop('${stationId}')">Parar</button>`;
        } else {
            actionButton = `<button class="btn-start" onclick="start('${stationId}')">Iniciar</button>`;
        }
    }

    if (session) {
        sessionText = session.isCharging 
            ? `<span class="green status">Carregando</span>` 
            : `<span class="red status">Parado</span>`;
    }

    deviceDiv.innerHTML = `
        <b>${stationId}</b><br/><br/>
        OCPP: ${ocppText}<br/>
        Sessão: ${sessionText}<br/><br/>
        ${actionButton}
    `;
}

// ==================== LOAD ALL (inicial) ====================
async function loadAll() {
    const container = document.getElementById("devices");
    container.innerHTML = "";

    try {
        const regRes = await fetch("/charging/ocpp/registered");
        if (!regRes.ok) {
            console.warn("Falha ao obter estações registradas", regRes.statusText);
            return;
        }

        const registered = await regRes.json();
        if (Array.isArray(registered)) {
            stations.length = 0;
            stations.push(...registered);
        }

        for (const id of stations) {
            try {
                const ocppRes = await fetch(`/charging/${id}/ocpp/status`);
                const ocppStatus = ocppRes.ok ? await ocppRes.json() : null;

                const sessionRes = await fetch(`/charging/${id}`);
                const session = sessionRes.ok ? await sessionRes.json() : null;

                updateDeviceUI(id, ocppStatus, session);
            } catch (e) {
                console.warn(`Erro ao carregar ${id}`, e);
            }
        }
    } catch (e) {
        console.error("Erro no loadAll:", e);
    }
}

// ==================== INICIALIZAÇÃO ====================
window.onload = () => {
    startSignalR();
};
</script>

</body>
</html>